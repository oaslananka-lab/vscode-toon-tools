{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TOON Configuration",
  "type": "object",
  "properties": {
    "version": { "type": "string", "description": "TOON schema version" },
    "defaultBlockName": { "type": "string", "default": "data" },
    "indentWidth": { "type": "integer", "enum": [2, 4], "default": 2 },
    "fieldSpacing": { "type": "string", "enum": ["compact", "spaced"], "default": "compact" }
  },
  "additionalProperties": false
}
