{
  "name": "vscode-toon-tools",
  "displayName": "TOON Tools",
  "publisher": "oaslananka",
  "version": "1.0.0",
  "description": "TOON format support: syntax highlighting, formatter, linter, hover, inlay hints, rename, JSON-to-TOON conversion, table viewer, and token-size analyzer.",
  "icon": "images/toon-tools-icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "toon",
    "token oriented object notation",
    "tabular data",
    "formatter",
    "linter",
    "json",
    "vscode-extension"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/vscode-toon-tools.git"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/vscode-toon-tools/issues"
  },
  "homepage": "https://github.com/oaslananka/vscode-toon-tools#readme",
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Linting and formatting work in untrusted workspaces. Conversion commands require a trusted workspace.",
      "restrictedConfigurations": []
    }
  },
  "activationEvents": [
    "onLanguage:toon",
    "onCommand:toon.convertJsonToToon",
    "onCommand:toon.convertToonToJson",
    "onCommand:toon.openJsonPreview",
    "onCommand:toon.openToonPreview",
    "onCommand:toon.openTableViewer",
    "onCommand:toon.analyzeSizeTokens",
    "onCommand:toon.exportCsv"
  ],
  "contributes": {
    "languages": [
      {
        "id": "toon",
        "aliases": [
          "TOON",
          "toon"
        ],
        "extensions": [
          ".toon"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/toon-file-light.svg",
          "dark": "./icons/toon-file-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "toon",
        "scopeName": "source.toon",
        "path": "./syntaxes/toon.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "toon",
        "path": "./snippets/toon.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "toon.convertJsonToToon",
        "title": "TOON: Convert JSON to TOON"
      },
      {
        "command": "toon.convertToonToJson",
        "title": "TOON: Convert TOON to JSON"
      },
      {
        "command": "toon.openJsonPreview",
        "title": "TOON: Open JSON Preview (side)"
      },
      {
        "command": "toon.openToonPreview",
        "title": "TOON: Open TOON Preview (side)"
      },
      {
        "command": "toon.openTableViewer",
        "title": "TOON: Open Table Viewer"
      },
      {
        "command": "toon.analyzeSizeTokens",
        "title": "TOON: Analyze Size / Tokens"
      },
      {
        "command": "toon.exportCsv",
        "title": "TOON: Export Block as CSV"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == toon",
          "command": "toon.openTableViewer",
          "group": "toon@1"
        },
        {
          "when": "resourceLangId == toon",
          "command": "toon.analyzeSizeTokens",
          "group": "toon@2"
        },
        {
          "when": "resourceLangId == toon",
          "command": "toon.exportCsv",
          "group": "toon@3"
        },
        {
          "when": "resourceLangId == toon",
          "command": "toon.convertToonToJson",
          "group": "toon@4"
        },
        {
          "when": "resourceLangId == json",
          "command": "toon.convertJsonToToon",
          "group": "toon@1"
        }
      ]
    },
    "configuration": {
      "title": "TOON Tools",
      "properties": {
        "toon.linter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time TOON linting."
        },
        "toon.linter.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 5000,
          "description": "Debounce delay (ms) for linting on change."
        },
        "toon.formatter.indentWidth": {
          "type": "number",
          "default": 2,
          "enum": [
            2,
            4
          ],
          "description": "Number of spaces for row indentation."
        },
        "toon.formatter.fieldSpacing": {
          "type": "string",
          "default": "compact",
          "enum": [
            "compact",
            "spaced"
          ],
          "enumDescriptions": [
            "No spaces after commas: field1,field2",
            "Space after commas: field1, field2"
          ],
          "description": "Comma spacing style in header fields."
        },
        "toon.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show field-name inlay hints in data rows."
        },
        "toon.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show TOON block count in the status bar."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": ".toonrc",
        "url": "./schemas/toon-config.schema.json"
      }
    ]
  },
  "scripts": {
    "prepare": "husky",
    "vscode:prepublish": "npm run build:prod",
    "build": "webpack --mode production",
    "build:prod": "npm run build",
    "watch": "webpack --mode development --watch",
    "format": "prettier --ignore-unknown --write .",
    "format:check": "prettier --ignore-unknown --check .",
    "lint": "eslint src test scripts --ext .ts,.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit:ci": "npm audit --audit-level=high",
    "check:staged": "lint-staged",
    "check:bundle-size": "node scripts/check-bundle-size.js",
    "check:workspace-trust": "node scripts/check-untrusted-workspace.js",
    "check:ci": "npm run audit:ci && npm run format:check && npm run lint && npm run typecheck && npm run check:workspace-trust && npm run test:unit:coverage && npm run build && npm run package && npm run check:bundle-size",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test:unit": "jest --runInBand",
    "test:unit:coverage": "jest --runInBand --coverage",
    "test:integration": "npm run compile-tests && node ./out/test/integration/runTest.js",
    "package": "vsce package",
    "package:ls": "vsce ls --tree",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "publish:all": "bash scripts/publish.sh"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "diff": "9.0.0",
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.4",
    "@go-task/cli": "3.50.0",
    "@types/jest": "29.5.14",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "8.30.0",
    "@typescript-eslint/parser": "8.30.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.3.2",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.1.0",
    "mocha": "11.7.5",
    "ovsx": "0.10.1",
    "prettier": "3.5.3",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "typescript": "5.8.3",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  },
  "dependencies": {}
}
